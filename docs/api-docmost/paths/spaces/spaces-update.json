{
  "operationId": "updateSpace",
  "tags": [
    "Spaces"
  ],
  "summary": "Update space settings",
  "description": "Requires Manage/Settings space permission.",
  "requestBody": {
    "required": true,
    "content": {
      "application/json": {
        "schema": {
          "type": "object",
          "required": [
            "spaceId"
          ],
          "properties": {
            "spaceId": {
              "type": "string",
              "format": "uuid",
              "description": "ID of the space to update."
            },
            "name": {
              "type": "string",
              "minLength": 2,
              "maxLength": 100,
              "description": "New display name."
            },
            "slug": {
              "type": "string",
              "minLength": 2,
              "maxLength": 100,
              "description": "New URL slug. Must be unique within the workspace."
            },
            "description": {
              "type": "string",
              "description": "New description."
            },
            "disablePublicSharing": {
              "type": "boolean",
              "description": "If `true`, prevents creation of public shares for pages in this space. Existing shares are deleted."
            }
          }
        }
      }
    }
  },
  "responses": {
    "200": {
      "description": "Updated space",
      "content": {
        "application/json": {
          "schema": {
            "allOf": [
              {
                "type": "object",
                "properties": {
                  "data": {
                    "description": "Response payload"
                  },
                  "success": {
                    "type": "boolean",
                    "examples": [
                      true
                    ]
                  },
                  "status": {
                    "type": "integer",
                    "examples": [
                      200
                    ]
                  }
                }
              },
              {
                "type": "object",
                "properties": {
                  "data": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string",
                        "format": "uuid"
                      },
                      "name": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "slug": {
                        "type": "string"
                      },
                      "description": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "logo": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "defaultRole": {
                        "type": "string"
                      },
                      "visibility": {
                        "type": "string"
                      },
                      "settings": {
                        "type": [
                          "object",
                          "null"
                        ]
                      },
                      "creatorId": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "format": "uuid"
                      },
                      "workspaceId": {
                        "type": "string",
                        "format": "uuid"
                      },
                      "createdAt": {
                        "type": "string",
                        "format": "date-time"
                      },
                      "updatedAt": {
                        "type": "string",
                        "format": "date-time"
                      }
                    }
                  }
                }
              }
            ]
          }
        }
      }
    },
    "400": {
      "description": "Validation error",
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "statusCode": {
                "type": "integer"
              },
              "message": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                ]
              },
              "error": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "403": {
      "description": "Forbidden",
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "statusCode": {
                "type": "integer"
              },
              "message": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                ]
              },
              "error": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}