{
  "operationId": "createSpace",
  "tags": [
    "Spaces"
  ],
  "summary": "Create a new space",
  "description": "Requires Manage/Space workspace permission.",
  "requestBody": {
    "required": true,
    "content": {
      "application/json": {
        "schema": {
          "type": "object",
          "required": [
            "name",
            "slug"
          ],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 2,
              "maxLength": 100,
              "description": "Display name for the space."
            },
            "slug": {
              "type": "string",
              "minLength": 2,
              "maxLength": 100,
              "description": "URL-friendly identifier used in page URLs (e.g. `/s/my-space/page-slug`). Must be unique within the workspace. Alphanumeric and hyphens."
            },
            "description": {
              "type": "string",
              "description": "Optional space description."
            }
          }
        }
      }
    }
  },
  "responses": {
    "200": {
      "description": "Created space with member count",
      "content": {
        "application/json": {
          "schema": {
            "allOf": [
              {
                "type": "object",
                "properties": {
                  "data": {
                    "description": "Response payload"
                  },
                  "success": {
                    "type": "boolean",
                    "examples": [
                      true
                    ]
                  },
                  "status": {
                    "type": "integer",
                    "examples": [
                      200
                    ]
                  }
                }
              },
              {
                "type": "object",
                "properties": {
                  "data": {
                    "description": "Space with member count",
                    "allOf": [
                      {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string",
                            "format": "uuid"
                          },
                          "name": {
                            "type": [
                              "string",
                              "null"
                            ]
                          },
                          "slug": {
                            "type": "string"
                          },
                          "description": {
                            "type": [
                              "string",
                              "null"
                            ]
                          },
                          "logo": {
                            "type": [
                              "string",
                              "null"
                            ]
                          },
                          "defaultRole": {
                            "type": "string"
                          },
                          "visibility": {
                            "type": "string"
                          },
                          "settings": {
                            "type": [
                              "object",
                              "null"
                            ]
                          },
                          "creatorId": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "format": "uuid"
                          },
                          "workspaceId": {
                            "type": "string",
                            "format": "uuid"
                          },
                          "createdAt": {
                            "type": "string",
                            "format": "date-time"
                          },
                          "updatedAt": {
                            "type": "string",
                            "format": "date-time"
                          }
                        }
                      },
                      {
                        "type": "object",
                        "properties": {
                          "memberCount": {
                            "type": "integer"
                          }
                        }
                      }
                    ]
                  }
                }
              }
            ]
          }
        }
      }
    },
    "400": {
      "description": "Space slug already exists",
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "statusCode": {
                "type": "integer"
              },
              "message": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                ]
              },
              "error": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "403": {
      "description": "Forbidden",
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "statusCode": {
                "type": "integer"
              },
              "message": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                ]
              },
              "error": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}