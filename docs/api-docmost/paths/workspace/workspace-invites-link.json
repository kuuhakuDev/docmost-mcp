      "application/json": {
        "schema": {
          "type": "object",
          "required": [
            "invitationId"
          ],
          "properties": {
            "invitationId": {
              "type": "string",
              "format": "uuid"
            }
          }
        }
      }
    }
  },
  "responses": {
