{
  "operationId": "verifyResetToken",
  "tags": [
    "Auth"
  ],
  "summary": "Verify a password reset token",
  "security": [],
  "requestBody": {
    "required": true,
    "content": {
      "application/json": {
        "schema": {
          "type": "object",
          "required": [
            "token",
            "type"
          ],
          "properties": {
            "token": {
              "type": "string",
              "description": "Token string to verify."
            },
            "type": {
              "type": "string",
              "description": "Token type to validate against (e.g. `password-reset`)."
            }
          }
        }
      }
    }
  },
  "responses": {
    "200": {
      "description": "Token validity result",
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "data": {
                "description": "Response payload"
              },
              "success": {
                "type": "boolean",
                "examples": [
                  true
                ]
              },
              "status": {
                "type": "integer",
                "examples": [
                  200
                ]
              }
            }
          }
        }
      }
    },
    "400": {
      "description": "Invalid or expired token",
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "statusCode": {
                "type": "integer"
              },
              "message": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                ]
              },
              "error": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}