{
  "operationId": "searchSuggestions",
  "tags": [
    "Search"
  ],
  "summary": "Get search suggestions for pages, users, or groups",
  "requestBody": {
    "required": true,
    "content": {
      "application/json": {
        "schema": {
          "type": "object",
          "required": [
            "query"
          ],
          "description": "Provides autocomplete suggestions across users, groups, and pages.",
          "properties": {
            "query": {
              "type": "string",
              "description": "Search query for autocomplete suggestions."
            },
            "includeUsers": {
              "type": "boolean",
              "description": "If `true`, includes matching users in the suggestions."
            },
            "includeGroups": {
              "type": "boolean",
              "description": "If `true`, includes matching groups in the suggestions."
            },
            "includePages": {
              "type": "boolean",
              "description": "If `true`, includes matching pages in the suggestions."
            },
            "spaceId": {
              "type": "string",
              "description": "Restrict page suggestions to a specific space."
            },
            "limit": {
              "type": "integer",
              "description": "Maximum number of suggestions per category."
            }
          }
        }
      }
    }
  },
  "responses": {
    "200": {
      "description": "Suggestions grouped by type",
      "content": {
        "application/json": {
          "schema": {
            "allOf": [
              {
                "type": "object",
                "properties": {
                  "data": {
                    "description": "Response payload"
                  },
                  "success": {
                    "type": "boolean",
                    "examples": [
                      true
                    ]
                  },
                  "status": {
                    "type": "integer",
                    "examples": [
                      200
                    ]
                  }
                }
              },
              {
                "type": "object",
                "properties": {
                  "data": {
                    "type": "object",
                    "properties": {
                      "users": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "id": {
                              "type": "string",
                              "format": "uuid"
                            },
                            "name": {
                              "type": [
                                "string",
                                "null"
                              ]
                            },
                            "email": {
                              "type": "string"
                            },
                            "avatarUrl": {
                              "type": [
                                "string",
                                "null"
                              ]
                            }
                          }
                        }
                      },
                      "groups": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "id": {
                              "type": "string",
                              "format": "uuid"
                            },
                            "name": {
                              "type": "string"
                            },
                            "description": {
                              "type": [
                                "string",
                                "null"
                              ]
                            }
                          }
                        }
                      },
                      "pages": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "id": {
                              "type": "string",
                              "format": "uuid"
                            },
                            "slugId": {
                              "type": "string"
                            },
                            "title": {
                              "type": [
                                "string",
                                "null"
                              ]
                            },
                            "icon": {
                              "type": [
                                "string",
                                "null"
                              ]
                            },
                            "spaceId": {
                              "type": "string",
                              "format": "uuid"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            ]
          }
        }
      }
    },
    "401": {
      "description": "Unauthorized",
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "statusCode": {
                "type": "integer"
              },
              "message": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                ]
              },
              "error": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}