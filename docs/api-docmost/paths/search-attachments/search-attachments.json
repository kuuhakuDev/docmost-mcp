{
  "operationId": "searchAttachments",
  "tags": [
    "Attachment Search"
  ],
  "summary": "Search attachment content (EE)",
  "requestBody": {
    "required": true,
    "content": {
      "application/json": {
        "schema": {
          "type": "object",
          "required": [
            "query"
          ],
          "properties": {
            "query": {
              "type": "string",
              "description": "Full-text search query. Searches page titles and content."
            },
            "spaceId": {
              "type": "string",
              "description": "Restrict search results to a specific space. If omitted, searches across all spaces the user has access to."
            },
            "creatorId": {
              "type": "string",
              "description": "Filter results to pages created by a specific user."
            },
            "limit": {
              "type": "integer",
              "description": "Maximum number of results to return."
            },
            "offset": {
              "type": "integer",
              "description": "Number of results to skip for pagination."
            }
          }
        }
      }
    }
  },
  "responses": {
    "200": {
      "description": "Attachment search results",
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "data": {
                "description": "Response payload"
              },
              "success": {
                "type": "boolean",
                "examples": [
                  true
                ]
              },
              "status": {
                "type": "integer",
                "examples": [
                  200
                ]
              }
            }
          }
        }
      }
    },
    "403": {
      "description": "Forbidden",
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "statusCode": {
                "type": "integer"
              },
              "message": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                ]
              },
              "error": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}