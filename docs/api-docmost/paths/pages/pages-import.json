{
  "operationId": "importPage",
  "tags": [
    "Import"
  ],
  "summary": "Import a single file (md, html, docx)",
  "requestBody": {
    "required": true,
    "content": {
      "multipart/form-data": {
        "schema": {
          "type": "object",
          "required": [
            "file",
            "spaceId"
          ],
          "properties": {
            "file": {
              "type": "string",
              "format": "binary",
              "description": "File to import. Supported formats: `.md` (Markdown), `.html` (HTML), `.docx` (Word document). Max 10 MB."
            },
            "spaceId": {
              "type": "string",
              "format": "uuid",
              "description": "ID of the space to import the page into."
            },
            "parentPageId": {
              "type": "string",
              "format": "uuid",
              "description": "ID of the parent page. If provided, the imported page is created as a child. If omitted, created at root level."
            }
          }
        }
      }
    }
  },
  "responses": {
    "200": {
      "description": "Imported page",
      "content": {
        "application/json": {
          "schema": {
            "allOf": [
              {
                "type": "object",
                "properties": {
                  "data": {
                    "description": "Response payload"
                  },
                  "success": {
                    "type": "boolean",
                    "examples": [
                      true
                    ]
                  },
                  "status": {
                    "type": "integer",
                    "examples": [
                      200
                    ]
                  }
                }
              },
              {
                "type": "object",
                "properties": {
                  "data": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string",
                        "format": "uuid"
                      },
                      "slugId": {
                        "type": "string"
                      },
                      "title": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "icon": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "coverPhoto": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "content": {
                        "description": "JSON content (ProseMirror document) or converted format",
                        "oneOf": [
                          {
                            "type": "object"
                          },
                          {
                            "type": "string"
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "position": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "parentPageId": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "format": "uuid"
                      },
                      "spaceId": {
                        "type": "string",
                        "format": "uuid"
                      },
                      "creatorId": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "format": "uuid"
                      },
                      "lastUpdatedById": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "format": "uuid"
                      },
                      "isLocked": {
                        "type": "boolean"
                      },
                      "contributorIds": {
                        "type": [
                          "array",
                          "null"
                        ],
                        "items": {
                          "type": "string"
                        }
                      },
                      "workspaceId": {
                        "type": "string",
                        "format": "uuid"
                      },
                      "createdAt": {
                        "type": "string",
                        "format": "date-time"
                      },
                      "updatedAt": {
                        "type": "string",
                        "format": "date-time"
                      },
                      "deletedAt": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "format": "date-time"
                      }
                    }
                  }
                }
              }
            ]
          }
        }
      }
    },
    "400": {
      "description": "Validation error",
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "statusCode": {
                "type": "integer"
              },
              "message": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                ]
              },
              "error": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "403": {
      "description": "Forbidden",
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "statusCode": {
                "type": "integer"
              },
              "message": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                ]
              },
              "error": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}