{
  "operationId": "deletePage",
  "tags": [
    "Pages"
  ],
  "summary": "Delete a page (soft or permanent)",
  "requestBody": {
    "required": true,
    "content": {
      "application/json": {
        "schema": {
          "type": "object",
          "required": [
            "pageId"
          ],
          "properties": {
            "pageId": {
              "type": "string",
              "description": "ID of the page to delete."
            },
            "permanentlyDelete": {
              "type": "boolean",
              "description": "If `true`, permanently deletes the page and all its descendants from the database (requires space admin permission). If `false` (default), soft-deletes the page by setting `deletedAt` — it can be restored later from the trash."
            }
          }
        }
      }
    }
  },
  "responses": {
    "200": {
      "description": "Page deleted",
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "data": {
                "description": "Response payload"
              },
              "success": {
                "type": "boolean",
                "examples": [
                  true
                ]
              },
              "status": {
                "type": "integer",
                "examples": [
                  200
                ]
              }
            }
          }
        }
      }
    },
    "403": {
      "description": "Forbidden",
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "statusCode": {
                "type": "integer"
              },
              "message": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                ]
              },
              "error": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "404": {
      "description": "Page not found",
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "statusCode": {
                "type": "integer"
              },
              "message": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                ]
              },
              "error": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}