{
  "operationId": "updatePage",
  "tags": [
    "Pages"
  ],
  "summary": "Update a page",
  "requestBody": {
    "required": true,
    "content": {
      "application/json": {
        "schema": {
          "type": "object",
          "required": [
            "pageId"
          ],
          "properties": {
            "pageId": {
              "type": "string",
              "description": "ID of the page to update."
            },
            "title": {
              "type": "string",
              "description": "New page title."
            },
            "icon": {
              "type": "string",
              "description": "New page icon (emoji or icon string)."
            },
            "content": {
              "description": "New content to apply. The expected type depends on `format`: `json` expects a ProseMirror document object, `markdown` expects a Markdown string, `html` expects an HTML string. How the content is applied depends on `operation`."
            },
            "format": {
              "type": "string",
              "enum": [
                "json",
                "markdown",
                "html"
              ],
              "description": "Format of the `content` field. Required when `content` is provided. `json`: ProseMirror document JSON. `markdown`: Markdown text. `html`: HTML text. The response content will also be in this format."
            },
            "operation": {
              "type": "string",
              "enum": [
                "append",
                "prepend",
                "replace"
              ],
              "description": "How to apply the new content to the existing page. `replace` (default): removes all existing content and inserts the new content. `append`: inserts the new content at the end of the existing document. `prepend`: inserts the new content at the beginning of the existing document."
            }
          }
        }
      }
    }
  },
  "responses": {
    "200": {
      "description": "Updated page with nested creator, lastUpdatedBy, contributors, and space",
      "content": {
        "application/json": {
          "schema": {
            "allOf": [
              {
                "type": "object",
                "properties": {
                  "data": {
                    "description": "Response payload"
                  },
                  "success": {
                    "type": "boolean",
                    "examples": [
                      true
                    ]
                  },
                  "status": {
                    "type": "integer",
                    "examples": [
                      200
                    ]
                  }
                }
              },
              {
                "type": "object",
                "properties": {
                  "data": {
                    "description": "Page with conditionally included nested objects",
                    "allOf": [
                      {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string",
                            "format": "uuid"
                          },
                          "slugId": {
                            "type": "string"
                          },
                          "title": {
                            "type": [
                              "string",
                              "null"
                            ]
                          },
                          "icon": {
                            "type": [
                              "string",
                              "null"
                            ]
                          },
                          "coverPhoto": {
                            "type": [
                              "string",
                              "null"
                            ]
                          },
                          "content": {
                            "description": "JSON content (ProseMirror document) or converted format",
                            "oneOf": [
                              {
                                "type": "object"
                              },
                              {
                                "type": "string"
                              },
                              {
                                "type": "null"
                              }
                            ]
                          },
                          "position": {
                            "type": [
                              "string",
                              "null"
                            ]
                          },
                          "parentPageId": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "format": "uuid"
                          },
                          "spaceId": {
                            "type": "string",
                            "format": "uuid"
                          },
                          "creatorId": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "format": "uuid"
                          },
                          "lastUpdatedById": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "format": "uuid"
                          },
                          "isLocked": {
                            "type": "boolean"
                          },
                          "contributorIds": {
                            "type": [
                              "array",
                              "null"
                            ],
                            "items": {
                              "type": "string"
                            }
                          },
                          "workspaceId": {
                            "type": "string",
                            "format": "uuid"
                          },
                          "createdAt": {
                            "type": "string",
                            "format": "date-time"
                          },
                          "updatedAt": {
                            "type": "string",
                            "format": "date-time"
                          },
                          "deletedAt": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "format": "date-time"
                          }
                        }
                      },
                      {
                        "type": "object",
                        "properties": {
                          "creator": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "string",
                                "format": "uuid"
                              },
                              "name": {
                                "type": [
                                  "string",
                                  "null"
                                ]
                              },
                              "avatarUrl": {
                                "type": [
                                  "string",
                                  "null"
                                ]
                              }
                            }
                          },
                          "lastUpdatedBy": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "string",
                                "format": "uuid"
                              },
                              "name": {
                                "type": [
                                  "string",
                                  "null"
                                ]
                              },
                              "avatarUrl": {
                                "type": [
                                  "string",
                                  "null"
                                ]
                              }
                            }
                          },
                          "contributors": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "id": {
                                  "type": "string",
                                  "format": "uuid"
                                },
                                "name": {
                                  "type": [
                                    "string",
                                    "null"
                                  ]
                                },
                                "avatarUrl": {
                                  "type": [
                                    "string",
                                    "null"
                                  ]
                                }
                              }
                            }
                          },
                          "space": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "string",
                                "format": "uuid"
                              },
                              "name": {
                                "type": [
                                  "string",
                                  "null"
                                ]
                              },
                              "slug": {
                                "type": "string"
                              }
                            }
                          },
                          "hasChildren": {
                            "type": "boolean"
                          }
                        }
                      }
                    ]
                  }
                }
              }
            ]
          }
        }
      }
    },
    "400": {
      "description": "Invalid content format",
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "statusCode": {
                "type": "integer"
              },
              "message": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                ]
              },
              "error": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "403": {
      "description": "Forbidden",
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "statusCode": {
                "type": "integer"
              },
              "message": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                ]
              },
              "error": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "404": {
      "description": "Page not found",
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "statusCode": {
                "type": "integer"
              },
              "message": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                ]
              },
              "error": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}