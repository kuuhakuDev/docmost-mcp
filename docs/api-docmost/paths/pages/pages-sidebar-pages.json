{
  "operationId": "getSidebarPages",
  "tags": [
    "Pages"
  ],
  "summary": "Get pages for sidebar navigation",
  "description": "Requires spaceId or pageId.",
  "requestBody": {
    "required": true,
    "content": {
      "application/json": {
        "schema": {
          "allOf": [
            {
              "type": "object",
              "properties": {
                "spaceId": {
                  "type": "string",
                  "format": "uuid",
                  "description": "Space to list pages for. Returns root-level pages when `pageId` is not provided."
                },
                "pageId": {
                  "type": "string",
                  "description": "Parent page ID. If provided, returns the children of this page for lazy-loading the sidebar tree."
                }
              }
            },
            {
              "type": "object",
              "properties": {
                "limit": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 100,
                  "default": 20,
                  "description": "Maximum number of items to return per page."
                },
                "cursor": {
                  "type": "string",
                  "format": "base64",
                  "description": "Set cursor to `nextCursor` returned by the previous call to list items in the next page."
                },
                "query": {
                  "type": "string",
                  "description": "Optional text filter to search within the listed items (e.g. filter members by name)."
                },
                "adminView": {
                  "type": "boolean",
                  "description": "If `true`, the list includes all items the admin has global permissions to access by virtue of their admin role."
                }
              }
            }
          ]
        }
      }
    }
  },
  "responses": {
    "200": {
      "description": "Sidebar pages",
      "content": {
        "application/json": {
          "schema": {
            "allOf": [
              {
                "type": "object",
                "properties": {
                  "data": {
                    "description": "Response payload"
                  },
                  "success": {
                    "type": "boolean",
                    "examples": [
                      true
                    ]
                  },
                  "status": {
                    "type": "integer",
                    "examples": [
                      200
                    ]
                  }
                }
              },
              {
                "type": "object",
                "properties": {
                  "data": {
                    "type": "object",
                    "properties": {
                      "items": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "id": {
                              "type": "string",
                              "format": "uuid"
                            },
                            "slugId": {
                              "type": "string"
                            },
                            "title": {
                              "type": [
                                "string",
                                "null"
                              ]
                            },
                            "icon": {
                              "type": [
                                "string",
                                "null"
                              ]
                            },
                            "position": {
                              "type": [
                                "string",
                                "null"
                              ]
                            },
                            "parentPageId": {
                              "type": [
                                "string",
                                "null"
                              ],
                              "format": "uuid"
                            },
                            "hasChildren": {
                              "type": "boolean"
                            },
                            "spaceId": {
                              "type": "string",
                              "format": "uuid"
                            }
                          }
                        }
                      },
                      "meta": {
                        "type": "object",
                        "properties": {
                          "limit": {
                            "type": "integer"
                          },
                          "hasNextPage": {
                            "type": "boolean"
                          },
                          "hasPrevPage": {
                            "type": "boolean"
                          },
                          "nextCursor": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "format": "base64"
                          },
                          "prevCursor": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "format": "base64"
                          }
                        }
                      }
                    }
                  }
                }
              }
            ]
          }
        }
      }
    },
    "400": {
      "description": "spaceId or pageId required",
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "statusCode": {
                "type": "integer"
              },
              "message": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                ]
              },
              "error": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "403": {
      "description": "Forbidden",
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "statusCode": {
                "type": "integer"
              },
              "message": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                ]
              },
              "error": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}