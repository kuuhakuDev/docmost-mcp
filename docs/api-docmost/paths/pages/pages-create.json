{
  "operationId": "createPage",
  "tags": [
    "Pages"
  ],
  "summary": "Create a new page",
  "requestBody": {
    "required": true,
    "content": {
      "application/json": {
        "schema": {
          "type": "object",
          "required": [
            "spaceId"
          ],
          "properties": {
            "spaceId": {
              "type": "string",
              "format": "uuid",
              "description": "ID of the space to create the page in."
            },
            "title": {
              "type": "string",
              "description": "Page title. Can be empty."
            },
            "icon": {
              "type": "string",
              "description": "Emoji or icon string displayed alongside the page title."
            },
            "parentPageId": {
              "type": "string",
              "description": "ID of the parent page. If provided, creates the page as a child (sub-page). If omitted, creates a root-level page in the space."
            },
            "content": {
              "description": "Page body content. The expected type depends on `format`: `json` expects a ProseMirror document object, `markdown` expects a Markdown string, `html` expects an HTML string."
            },
            "format": {
              "type": "string",
              "enum": [
                "json",
                "markdown",
                "html"
              ],
              "description": "Format of the `content` field. Required when `content` is provided. `json`: ProseMirror document JSON object. `markdown`: Markdown text, converted to ProseMirror JSON on save. `html`: HTML text, converted to ProseMirror JSON on save."
            }
          }
        }
      }
    }
  },
  "responses": {
    "200": {
      "description": "Created page",
      "content": {
        "application/json": {
          "schema": {
            "allOf": [
              {
                "type": "object",
                "properties": {
                  "data": {
                    "description": "Response payload"
                  },
                  "success": {
                    "type": "boolean",
                    "examples": [
                      true
                    ]
                  },
                  "status": {
                    "type": "integer",
                    "examples": [
                      200
                    ]
                  }
                }
              },
              {
                "type": "object",
                "properties": {
                  "data": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string",
                        "format": "uuid"
                      },
                      "slugId": {
                        "type": "string"
                      },
                      "title": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "icon": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "coverPhoto": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "content": {
                        "description": "JSON content (ProseMirror document) or converted format",
                        "oneOf": [
                          {
                            "type": "object"
                          },
                          {
                            "type": "string"
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "position": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "parentPageId": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "format": "uuid"
                      },
                      "spaceId": {
                        "type": "string",
                        "format": "uuid"
                      },
                      "creatorId": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "format": "uuid"
                      },
                      "lastUpdatedById": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "format": "uuid"
                      },
                      "isLocked": {
                        "type": "boolean"
                      },
                      "contributorIds": {
                        "type": [
                          "array",
                          "null"
                        ],
                        "items": {
                          "type": "string"
                        }
                      },
                      "workspaceId": {
                        "type": "string",
                        "format": "uuid"
                      },
                      "createdAt": {
                        "type": "string",
                        "format": "date-time"
                      },
                      "updatedAt": {
                        "type": "string",
                        "format": "date-time"
                      },
                      "deletedAt": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "format": "date-time"
                      }
                    }
                  }
                }
              }
            ]
          }
        }
      }
    },
    "400": {
      "description": "Parent page not found",
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "statusCode": {
                "type": "integer"
              },
              "message": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                ]
              },
              "error": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "403": {
      "description": "Forbidden",
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "statusCode": {
                "type": "integer"
              },
              "message": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                ]
              },
              "error": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}