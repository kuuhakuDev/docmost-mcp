{
  "operationId": "importZip",
  "tags": [
    "Import"
  ],
  "summary": "Import a zip archive (Notion, Confluence, or generic)",
  "description": "Imports are processed asynchronously. Returns a file task that can be polled for progress.",
  "requestBody": {
    "required": true,
    "content": {
      "multipart/form-data": {
        "schema": {
          "type": "object",
          "required": [
            "file",
            "spaceId",
            "source"
          ],
          "properties": {
            "file": {
              "type": "string",
              "format": "binary",
              "description": "ZIP archive containing pages to import."
            },
            "spaceId": {
              "type": "string",
              "format": "uuid",
              "description": "ID of the space to import pages into."
            },
            "source": {
              "type": "string",
              "enum": [
                "notion",
                "confluence",
                "generic"
              ],
              "description": "Source format of the zip contents. `notion`: Notion export (HTML or Markdown). `confluence`: Confluence space export (HTML format). `generic`: generic zip of Markdown or HTML files."
            },
            "parentPageId": {
              "type": "string",
              "format": "uuid",
              "description": "ID of the parent page. Imported pages are created as children of this page. If omitted, imported at root level."
            }
          }
        }
      }
    }
  },
  "responses": {
    "200": {
      "description": "Async file task created",
      "content": {
        "application/json": {
          "schema": {
            "allOf": [
              {
                "type": "object",
                "properties": {
                  "data": {
                    "description": "Response payload"
                  },
                  "success": {
                    "type": "boolean",
                    "examples": [
                      true
                    ]
                  },
                  "status": {
                    "type": "integer",
                    "examples": [
                      200
                    ]
                  }
                }
              },
              {
                "type": "object",
                "properties": {
                  "data": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string",
                        "format": "uuid"
                      },
                      "fileName": {
                        "type": "string"
                      },
                      "fileExt": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "filePath": {
                        "type": "string"
                      },
                      "fileSize": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "type": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "source": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "status": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "errorMessage": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "creatorId": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "format": "uuid"
                      },
                      "spaceId": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "format": "uuid"
                      },
                      "workspaceId": {
                        "type": "string",
                        "format": "uuid"
                      },
                      "createdAt": {
                        "type": "string",
                        "format": "date-time"
                      },
                      "updatedAt": {
                        "type": "string",
                        "format": "date-time"
                      }
                    }
                  }
                }
              }
            ]
          }
        }
      }
    },
    "400": {
      "description": "Validation error",
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "statusCode": {
                "type": "integer"
              },
              "message": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                ]
              },
              "error": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "403": {
      "description": "Forbidden",
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "statusCode": {
                "type": "integer"
              },
              "message": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                ]
              },
              "error": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}