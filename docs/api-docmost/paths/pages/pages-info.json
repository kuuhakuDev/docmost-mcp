{
  "operationId": "getPage",
  "tags": [
    "Pages"
  ],
  "summary": "Get page details",
  "requestBody": {
    "required": true,
    "content": {
      "application/json": {
        "schema": {
          "type": "object",
          "required": [
            "pageId"
          ],
          "properties": {
            "pageId": {
              "type": "string",
              "description": "Page identifier (UUID or slug ID)."
            },
            "includeSpace": {
              "type": "boolean",
              "description": "If `true`, includes the space object (`id`, `name`, `slug`) in the response."
            },
            "includeContent": {
              "type": "boolean",
              "description": "If `true`, includes the page content body in the response. Omit or set to `false` when you only need page metadata."
            },
            "format": {
              "type": "string",
              "enum": [
                "json",
                "markdown",
                "html"
              ],
              "description": "Output format for the content field. `json` (default): ProseMirror document JSON. `markdown`: plain Markdown text. `html`: rendered HTML. Only applies when `includeContent` is `true`."
            }
          }
        }
      }
    }
  },
  "responses": {
    "200": {
      "description": "Page data with nested creator, lastUpdatedBy, contributors, and space",
      "content": {
        "application/json": {
          "schema": {
            "allOf": [
              {
                "type": "object",
                "properties": {
                  "data": {
                    "description": "Response payload"
                  },
                  "success": {
                    "type": "boolean",
                    "examples": [
                      true
                    ]
                  },
                  "status": {
                    "type": "integer",
                    "examples": [
                      200
                    ]
                  }
                }
              },
              {
                "type": "object",
                "properties": {
                  "data": {
                    "description": "Page with conditionally included nested objects",
                    "allOf": [
                      {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string",
                            "format": "uuid"
                          },
                          "slugId": {
                            "type": "string"
                          },
                          "title": {
                            "type": [
                              "string",
                              "null"
                            ]
                          },
                          "icon": {
                            "type": [
                              "string",
                              "null"
                            ]
                          },
                          "coverPhoto": {
                            "type": [
                              "string",
                              "null"
                            ]
                          },
                          "content": {
                            "description": "JSON content (ProseMirror document) or converted format",
                            "oneOf": [
                              {
                                "type": "object"
                              },
                              {
                                "type": "string"
                              },
                              {
                                "type": "null"
                              }
                            ]
                          },
                          "position": {
                            "type": [
                              "string",
                              "null"
                            ]
                          },
                          "parentPageId": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "format": "uuid"
                          },
                          "spaceId": {
                            "type": "string",
                            "format": "uuid"
                          },
                          "creatorId": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "format": "uuid"
                          },
                          "lastUpdatedById": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "format": "uuid"
                          },
                          "isLocked": {
                            "type": "boolean"
                          },
                          "contributorIds": {
                            "type": [
                              "array",
                              "null"
                            ],
                            "items": {
                              "type": "string"
                            }
                          },
                          "workspaceId": {
                            "type": "string",
                            "format": "uuid"
                          },
                          "createdAt": {
                            "type": "string",
                            "format": "date-time"
                          },
                          "updatedAt": {
                            "type": "string",
                            "format": "date-time"
                          },
                          "deletedAt": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "format": "date-time"
                          }
                        }
                      },
                      {
                        "type": "object",
                        "properties": {
                          "creator": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "string",
                                "format": "uuid"
                              },
                              "name": {
                                "type": [
                                  "string",
                                  "null"
                                ]
                              },
                              "avatarUrl": {
                                "type": [
                                  "string",
                                  "null"
                                ]
                              }
                            }
                          },
                          "lastUpdatedBy": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "string",
                                "format": "uuid"
                              },
                              "name": {
                                "type": [
                                  "string",
                                  "null"
                                ]
                              },
                              "avatarUrl": {
                                "type": [
                                  "string",
                                  "null"
                                ]
                              }
                            }
                          },
                          "contributors": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "id": {
                                  "type": "string",
                                  "format": "uuid"
                                },
                                "name": {
                                  "type": [
                                    "string",
                                    "null"
                                  ]
                                },
                                "avatarUrl": {
                                  "type": [
                                    "string",
                                    "null"
                                  ]
                                }
                              }
                            }
                          },
                          "space": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "string",
                                "format": "uuid"
                              },
                              "name": {
                                "type": [
                                  "string",
                                  "null"
                                ]
                              },
                              "slug": {
                                "type": "string"
                              }
                            }
                          },
                          "hasChildren": {
                            "type": "boolean"
                          }
                        }
                      }
                    ]
                  }
                }
              }
            ]
          }
        }
      }
    },
    "403": {
      "description": "Forbidden",
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "statusCode": {
                "type": "integer"
              },
              "message": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                ]
              },
              "error": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "404": {
      "description": "Page not found",
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "statusCode": {
                "type": "integer"
              },
              "message": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                ]
              },
              "error": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}