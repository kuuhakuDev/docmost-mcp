{
  "operationId": "getFileTasks",
  "tags": [
    "File Tasks"
  ],
  "summary": "List async import tasks",
  "requestBody": {
    "required": true,
    "content": {
      "application/json": {
        "schema": {
          "type": "object",
          "properties": {
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 20,
              "description": "Maximum number of items to return per page."
            },
            "cursor": {
              "type": "string",
              "format": "base64",
              "description": "Set cursor to `nextCursor` returned by the previous call to list items in the next page."
            },
            "query": {
              "type": "string",
              "description": "Optional text filter to search within the listed items (e.g. filter members by name)."
            },
            "adminView": {
              "type": "boolean",
              "description": "If `true`, the list includes all items the admin has global permissions to access by virtue of their admin role."
            }
          }
        }
      }
    }
  },
  "responses": {
    "200": {
      "description": "Paginated file tasks",
      "content": {
        "application/json": {
          "schema": {
            "allOf": [
              {
                "type": "object",
                "properties": {
                  "data": {
                    "description": "Response payload"
                  },
                  "success": {
                    "type": "boolean",
                    "examples": [
                      true
                    ]
                  },
                  "status": {
                    "type": "integer",
                    "examples": [
                      200
                    ]
                  }
                }
              },
              {
                "type": "object",
                "properties": {
                  "data": {
                    "type": "object",
                    "properties": {
                      "items": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "id": {
                              "type": "string",
                              "format": "uuid"
                            },
                            "fileName": {
                              "type": "string"
                            },
                            "fileExt": {
                              "type": [
                                "string",
                                "null"
                              ]
                            },
                            "filePath": {
                              "type": "string"
                            },
                            "fileSize": {
                              "type": [
                                "string",
                                "null"
                              ]
                            },
                            "type": {
                              "type": [
                                "string",
                                "null"
                              ]
                            },
                            "source": {
                              "type": [
                                "string",
                                "null"
                              ]
                            },
                            "status": {
                              "type": [
                                "string",
                                "null"
                              ]
                            },
                            "errorMessage": {
                              "type": [
                                "string",
                                "null"
                              ]
                            },
                            "creatorId": {
                              "type": [
                                "string",
                                "null"
                              ],
                              "format": "uuid"
                            },
                            "spaceId": {
                              "type": [
                                "string",
                                "null"
                              ],
                              "format": "uuid"
                            },
                            "workspaceId": {
                              "type": "string",
                              "format": "uuid"
                            },
                            "createdAt": {
                              "type": "string",
                              "format": "date-time"
                            },
                            "updatedAt": {
                              "type": "string",
                              "format": "date-time"
                            }
                          }
                        }
                      },
                      "meta": {
                        "type": "object",
                        "properties": {
                          "limit": {
                            "type": "integer"
                          },
                          "hasNextPage": {
                            "type": "boolean"
                          },
                          "hasPrevPage": {
                            "type": "boolean"
                          },
                          "nextCursor": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "format": "base64"
                          },
                          "prevCursor": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "format": "base64"
                          }
                        }
                      }
                    }
                  }
                }
              }
            ]
          }
        }
      }
    },
    "403": {
      "description": "Forbidden",
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "statusCode": {
                "type": "integer"
              },
              "message": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                ]
              },
              "error": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}