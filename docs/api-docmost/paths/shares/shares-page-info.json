{
  "operationId": "getSharedPageInfo",
  "tags": [
    "Shares"
  ],
  "summary": "Get shared page info (public)",
  "security": [],
  "requestBody": {
    "required": true,
    "content": {
      "application/json": {
        "schema": {
          "type": "object",
          "description": "Provide at least one of `shareId` or `pageId` to look up shared page info.",
          "properties": {
            "shareId": {
              "type": "string",
              "description": "Share identifier. If the page has a direct share, look it up by this ID."
            },
            "pageId": {
              "type": "string",
              "description": "Page identifier. Resolves the share by traversing up the page tree to find an ancestor share with `includeSubPages` enabled."
            }
          }
        }
      }
    }
  },
  "responses": {
    "200": {
      "description": "Shared page with share and creator info",
      "content": {
        "application/json": {
          "schema": {
            "allOf": [
              {
                "type": "object",
                "properties": {
                  "data": {
                    "description": "Response payload"
                  },
                  "success": {
                    "type": "boolean",
                    "examples": [
                      true
                    ]
                  },
                  "status": {
                    "type": "integer",
                    "examples": [
                      200
                    ]
                  }
                }
              },
              {
                "type": "object",
                "properties": {
                  "data": {
                    "type": "object",
                    "properties": {
                      "page": {
                        "description": "Page with conditionally included nested objects",
                        "allOf": [
                          {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "string",
                                "format": "uuid"
                              },
                              "slugId": {
                                "type": "string"
                              },
                              "title": {
                                "type": [
                                  "string",
                                  "null"
                                ]
                              },
                              "icon": {
                                "type": [
                                  "string",
                                  "null"
                                ]
                              },
                              "coverPhoto": {
                                "type": [
                                  "string",
                                  "null"
                                ]
                              },
                              "content": {
                                "description": "JSON content (ProseMirror document) or converted format",
                                "oneOf": [
                                  {
                                    "type": "object"
                                  },
                                  {
                                    "type": "string"
                                  },
                                  {
                                    "type": "null"
                                  }
                                ]
                              },
                              "position": {
                                "type": [
                                  "string",
                                  "null"
                                ]
                              },
                              "parentPageId": {
                                "type": [
                                  "string",
                                  "null"
                                ],
                                "format": "uuid"
                              },
                              "spaceId": {
                                "type": "string",
                                "format": "uuid"
                              },
                              "creatorId": {
                                "type": [
                                  "string",
                                  "null"
                                ],
                                "format": "uuid"
                              },
                              "lastUpdatedById": {
                                "type": [
                                  "string",
                                  "null"
                                ],
                                "format": "uuid"
                              },
                              "isLocked": {
                                "type": "boolean"
                              },
                              "contributorIds": {
                                "type": [
                                  "array",
                                  "null"
                                ],
                                "items": {
                                  "type": "string"
                                }
                              },
                              "workspaceId": {
                                "type": "string",
                                "format": "uuid"
                              },
                              "createdAt": {
                                "type": "string",
                                "format": "date-time"
                              },
                              "updatedAt": {
                                "type": "string",
                                "format": "date-time"
                              },
                              "deletedAt": {
                                "type": [
                                  "string",
                                  "null"
                                ],
                                "format": "date-time"
                              }
                            }
                          },
                          {
                            "type": "object",
                            "properties": {
                              "creator": {
                                "type": "object",
                                "properties": {
                                  "id": {
                                    "type": "string",
                                    "format": "uuid"
                                  },
                                  "name": {
                                    "type": [
                                      "string",
                                      "null"
                                    ]
                                  },
                                  "avatarUrl": {
                                    "type": [
                                      "string",
                                      "null"
                                    ]
                                  }
                                }
                              },
                              "lastUpdatedBy": {
                                "type": "object",
                                "properties": {
                                  "id": {
                                    "type": "string",
                                    "format": "uuid"
                                  },
                                  "name": {
                                    "type": [
                                      "string",
                                      "null"
                                    ]
                                  },
                                  "avatarUrl": {
                                    "type": [
                                      "string",
                                      "null"
                                    ]
                                  }
                                }
                              },
                              "contributors": {
                                "type": "array",
                                "items": {
                                  "type": "object",
                                  "properties": {
                                    "id": {
                                      "type": "string",
                                      "format": "uuid"
                                    },
                                    "name": {
                                      "type": [
                                        "string",
                                        "null"
                                      ]
                                    },
                                    "avatarUrl": {
                                      "type": [
                                        "string",
                                        "null"
                                      ]
                                    }
                                  }
                                }
                              },
                              "space": {
                                "type": "object",
                                "properties": {
                                  "id": {
                                    "type": "string",
                                    "format": "uuid"
                                  },
                                  "name": {
                                    "type": [
                                      "string",
                                      "null"
                                    ]
                                  },
                                  "slug": {
                                    "type": "string"
                                  }
                                }
                              },
                              "hasChildren": {
                                "type": "boolean"
                              }
                            }
                          }
                        ]
                      },
                      "share": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string",
                            "format": "uuid"
                          },
                          "key": {
                            "type": "string"
                          },
                          "pageId": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "format": "uuid"
                          },
                          "includeSubPages": {
                            "type": [
                              "boolean",
                              "null"
                            ]
                          },
                          "searchIndexing": {
                            "type": [
                              "boolean",
                              "null"
                            ]
                          },
                          "creatorId": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "format": "uuid"
                          },
                          "spaceId": {
                            "type": "string",
                            "format": "uuid"
                          },
                          "workspaceId": {
                            "type": "string",
                            "format": "uuid"
                          },
                          "createdAt": {
                            "type": "string",
                            "format": "date-time"
                          },
                          "updatedAt": {
                            "type": "string",
                            "format": "date-time"
                          }
                        }
                      }
                    }
                  }
                }
              }
            ]
          }
        }
      }
    },
    "400": {
      "description": "pageId or shareId required",
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "statusCode": {
                "type": "integer"
              },
              "message": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                ]
              },
              "error": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "404": {
      "description": "Shared page not found",
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "statusCode": {
                "type": "integer"
              },
              "message": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                ]
              },
              "error": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}